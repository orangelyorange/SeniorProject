  m_Script: {fileID: 11500000, guid: 199efc4acd2248918995423737fa90a2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  questID: HerbalistQuest
  questStartDialogue:
  - I feel so lonely! My son has died because of an illness!
  - I would like to gather santan flowers on his grave, because he loved them so
    much!
  - Please help me!
  questReminderDialogue:
  - There are a lot of flowers scattered
  - 'I hope you can find them '
  questSuccessDialogue:
  - You found them? My heart is so relieved!
  - Thank you!
  - My son can now rest in peace!
  afterCompletionDialogue: []
  isTalking: 0
