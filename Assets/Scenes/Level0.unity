--- !u!114 &574985756240505121
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7854789025758373531}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 199efc4acd2248918995423737fa90a2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  questID: FarmerQuest
  questStartDialogue:
  - Hello, kind soul. Today is a peaceful and wonderful day! It is the day of the
    blessed harvest!
  - Gugurang blessed us with such nice and healthy rice stalks. I have prayed all
    year for this,
  - But those cursed mice keeps stealing our rice stalks, especially the good ones!
  - Will you be so kind to help me find those stalks, I pray for your success.
  questReminderDialogue:
  - I hope you are not having any trouble collecting.
  - If you looked for the rats, you might find what you are looking for.
  questSuccessDialogue:
  - You did it! I am so glad that you are safe!
  - You are tuly blessed by the gods! Praise Gugurang!
  afterCompletionDialogue: []
  isTalking: 0
